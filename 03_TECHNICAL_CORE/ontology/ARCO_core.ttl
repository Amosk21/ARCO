@prefix :    <https://arco.ai/ontology/core#> .
@prefix bfo: <http://purl.obolibrary.org/obo/BFO_> .
@prefix ro:  <http://purl.obolibrary.org/obo/RO_> .
@prefix iao: <http://purl.obolibrary.org/obo/IAO_> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:<http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

<https://arco.ai/ontology/core> rdf:type owl:Ontology ;
  rdfs:label "ARCO Core (Gold Standard) — BFO/RO Aligned" ;
  rdfs:comment "Core ontology with OWL restrictions for computable reasoning + ICE-to-Reality grounding (IAO is_about) in an NCOR realism style. Uses ro:0000091 (has_disposition) per RO best practices." .

#################################################################
# 1) REALITY-SIDE UNIVERSALS (BFO)
#
# Design Decision: We use ro:0000091 (has_disposition) rather than
# ro:0000053 (bearer_of) because:
#   - has_disposition is more specific in the RO property hierarchy
#   - has_disposition has domain: independent continuant, range: disposition
#   - bearer_of is generic (covers qualities, roles, functions, dispositions)
#   - This aligns with OBO Foundry best practices
#################################################################

:System rdf:type owl:Class ;
  rdfs:label "AI System" ;
  rdfs:subClassOf bfo:0000027 ; # Object Aggregate
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty bfo:0000051 ; # has part
    owl:someValuesFrom :HardwareComponent
  ] .

:HardwareComponent rdf:type owl:Class ;
  rdfs:label "Hardware Component" ;
  rdfs:subClassOf bfo:0000030 ; # Object
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ro:0000091 ; # has disposition (RO-specific)
    owl:someValuesFrom :CapabilityDisposition
  ] .

:CapabilityDisposition rdf:type owl:Class ;
  rdfs:label "AI Capability Disposition" ;
  rdfs:subClassOf bfo:0000016 . # Disposition

:BiometricIdentificationCapability rdf:type owl:Class ;
  rdfs:label "Biometric Identification Capability" ;
  rdfs:comment "A capability-disposition whose realizations include identifying or verifying individuals via biometric characteristics." ;
  rdfs:subClassOf :CapabilityDisposition .

:OperationalProcess rdf:type owl:Class ;
  rdfs:label "Operational Process" ;
  rdfs:subClassOf bfo:0000015 ; # Process
  rdfs:subClassOf
    [ a owl:Restriction ; owl:onProperty ro:0000057 ; owl:someValuesFrom :System ] ,                 # has participant
    [ a owl:Restriction ; owl:onProperty bfo:0000055 ; owl:someValuesFrom :CapabilityDisposition ] . # realizes

#################################################################
# 2) REPRESENTATION-SIDE UNIVERSALS (IAO)
#################################################################

:InformationOutput rdf:type owl:Class ;
  rdfs:label "Information Output" ;
  rdfs:subClassOf iao:0000030 . # Information Content Entity

:RegulatoryContent rdf:type owl:Class ;
  rdfs:label "Regulatory Content" ;
  rdfs:subClassOf iao:0000030 . # Information Content Entity

:ComplianceDetermination rdf:type owl:Class ;
  rdfs:label "Compliance Determination Result" ;
  rdfs:comment "Structured result of a compliance assessment (e.g., High-Risk, Limited-Risk, Prohibited)." ;
  rdfs:subClassOf iao:0000030 . # Information Content Entity

:HighRiskDetermination rdf:type owl:Class ;
  rdfs:label "High-Risk Determination" ;
  rdfs:comment "A compliance determination that classifies a system as high-risk. Can be asserted when documenting an inferred HighRiskSystem classification." ;
  rdfs:subClassOf :ComplianceDetermination .

#################################################################
# 3) INFERRED CLASSIFICATION - Bridge Axioms
#
# These axioms enable the reasoner to INFER high-risk status
# rather than requiring it to be explicitly asserted.
#
# CRITICAL: Uses ro:0000091 (has_disposition) to match instance data
#################################################################

:AnnexIIITriggeringCapability rdf:type owl:Class ;
  rdfs:label "Annex III Triggering Capability" ;
  rdfs:comment "REGULATORY DEFINED CLASS. This is not a natural universal — it is a union class defined by the EU AI Act Annex III enumeration. Its members are those CapabilityDisposition subclasses that the regulation designates as high-risk triggers. Extend the union to add new triggering capabilities as Annex III evolves." ;
  owl:equivalentClass [
    rdf:type owl:Class ;
    owl:unionOf ( :BiometricIdentificationCapability )
  ] .

:HighRiskSystem rdf:type owl:Class ;
  rdfs:label "High-Risk AI System" ;
  rdfs:comment "COMPUTATIONAL DEFINED CLASS (inference artifact). This class is NOT a natural universal — it is a regulatory-defined equivalence axiom that enables the OWL-RL reasoner to INFER high-risk status from structural evidence. A system satisfies this definition iff it has a part that bears an Annex III triggering capability disposition. Membership is never asserted directly; it is always derived by the reasoner from the bridge axiom below." ;
  owl:equivalentClass [
    rdf:type owl:Class ;
    owl:intersectionOf (
      :System
      [ rdf:type owl:Restriction ;
        owl:onProperty bfo:0000051 ; # has part
        owl:someValuesFrom [
          rdf:type owl:Restriction ;
          owl:onProperty ro:0000091 ; # has disposition (ALIGNED WITH INSTANCES)
          owl:someValuesFrom :AnnexIIITriggeringCapability
        ]
      ]
    )
  ] .

#################################################################
# 4) DISPOSITION-SCOPED INVERSE
#
# Design Decision: We do NOT declare ro:0000091 owl:inverseOf ro:0000052
# because ro:0000052 (inheres_in) is also used for Role inherence
# (e.g., ProviderRole ro:0000052 ProviderOrg). A global inverse would
# cause the reasoner to infer "ProviderOrg ro:0000091 ProviderRole",
# pulling roles into the disposition channel — a semantic drift error.
#
# Instead we introduce a local ARCO property :disposition_of that is
# the owl:inverseOf ro:0000091 only. This gives reverse traversal
# (Disposition -> Bearer) without contaminating role inherence.
#################################################################

:disposition_of rdf:type owl:ObjectProperty ;
  rdfs:label "disposition of" ;
  rdfs:comment "Inverse of ro:0000091 (has_disposition), scoped to disposition-bearer pairs only. Exists for query ergonomics — allows traversal from a disposition back to its independent continuant bearer without conflating with role inherence (ro:0000052)." ;
  owl:inverseOf ro:0000091 .

#################################################################
# 5) RELATION ANCHORS (labels for UI/debugging)
#################################################################

# BFO classes
bfo:0000015 rdfs:label "Process" .
bfo:0000016 rdfs:label "Disposition" .
bfo:0000023 rdfs:label "Role" .
bfo:0000027 rdfs:label "Object Aggregate" .
bfo:0000030 rdfs:label "Object" .

# BFO relations
bfo:0000050 rdfs:label "part of" .
bfo:0000051 rdfs:label "has part" .
bfo:0000055 rdfs:label "realizes" .

# RO relations
ro:0000052 rdfs:label "inheres in" .
ro:0000053 rdfs:label "bearer of" .
ro:0000057 rdfs:label "has participant" .
ro:0000087 rdfs:label "has role" .
ro:0000091 rdfs:label "has disposition" .

# IAO relations
iao:0000136 rdfs:label "is about" .
